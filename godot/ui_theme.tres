[gd_resource type="Theme" load_steps=2 format=3 uid="uid://bawofcjkthemev1"]

; Project-wide UI theme. The embedded SystemFont resolves a CJK-capable system
; font so Simplified Chinese renders correctly (avoids the default-font "tofu"
; □□□ problem). allow_system_fallback lets Latin/emoji fall back as needed.

[sub_resource type="SystemFont" id="SystemFont_cjk"]
font_names = PackedStringArray("Microsoft YaHei UI", "Microsoft YaHei", "SimHei", "Noto Sans CJK SC", "PingFang SC", "sans-serif")
allow_system_fallback = true
subpixel_positioning = 1

[resource]
default_font = SubResource("SystemFont_cjk")
default_font_size = 18
